    section.search 
      .search__container 
        h1.search__title The best place to buy top quality produsts for your pets 
        p.search__subtitle Shop by pet,brand or products on sale!

        form.search__form(action="")
          input.search__input(type="text", name="", placeholder="What are you looking for?")  
             

          button.search__btn Search 
      
      .search__img-container 
        img.search__img(src=require("./images/mops.WebP"), alt="mops")

    section.search--mobile
